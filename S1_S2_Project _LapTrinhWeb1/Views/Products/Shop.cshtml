@model IEnumerable<S1_S2_Project__LapTrinhWeb1.Models.Product>

<!DOCTYPE html>
<html>
<head>
    <title>Coffee Shop</title>

    <style>
        body {font-family: Arial;}
        .container {display: flex;flex-wrap: wrap;gap: 20px;}
        .card {border: 1px solid #ccc;width: 250px;padding: 15px;border-radius: 10px;box-shadow: 0 0 10px #ccc;}
        .card img {width: 100%;height: 180px;object-fit: cover;border-radius: 10px;}
        .price {color: red;font-weight: bold;}
    </style>
</head>
<body>
    <h1>Coffee Shop</h1>
    <div class="container">
        @foreach (var item in Model)
        {
            <div class="card">
                <img src="@item.ImageUrl" />
                <h2>@item.Name</h2>
                <p class="price">$@item.Price</p>
                <p>@item.Detail</p>
            </div>
        }
    </div>
</body>
</html>